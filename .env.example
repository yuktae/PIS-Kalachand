# ── REQUIRED ────────────────────────────────────────────────────────────────

# Flask session secret — MUST be set to a fixed random value in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: if this changes between restarts all active sessions are invalidated.
# In production (FLASK_ENV=production) the app refuses to start without this.
SECRET_KEY=change_this_to_a_long_random_string

# Google Gemini API Key (required for all AI generation)
GOOGLE_API_KEY=your_google_api_key_here

# Gemini model name. Override here when Google rotates the model (otherwise
# the SDK raises a model-not-found error with no obvious application cause).
# GEMINI_MODEL=gemini-2.5-flash

# PostgreSQL Database URL
# EasyPanel internal: postgresql://postgres:YOUR_PASSWORD@pis-postgres:5432/pis_system
# Local dev:          postgresql://postgres:postgres@localhost:5432/pis_system
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pis_system

# ── RUNTIME ──────────────────────────────────────────────────────────────────

# Set to "production" to enforce SECRET_KEY presence and tighten defaults.
# FLASK_ENV=production

# Port the dev server / Gunicorn binds to (default 5000).
# PORT=5000

# ── RATE LIMITING ────────────────────────────────────────────────────────────

# Redis URL for distributed rate limiting across Gunicorn workers.
# Without this, each worker tracks limits independently (effectively multiplying
# allowed rates by the worker count). Required for brute-force protection to work.
# EasyPanel: redis://pis-redis:6379/0
# Local dev: leave unset to use per-process memory (acceptable for development)
# REDIS_URL=redis://localhost:6379/0

# ── AZURE BLOB STORAGE ───────────────────────────────────────────────────────

# If set, images are uploaded to Azure Blob Storage (private) instead of local disk.
# Blobs are private — the app generates short-lived SAS tokens for browser access.
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=pis-images

# ── IMAGE SEARCH ─────────────────────────────────────────────────────────────

# Google Custom Search (used for product image lookup; optional — falls back to
# DuckDuckGo and Brave). Requires both a key and a CX (search engine ID).
# GOOGLE_SEARCH_CX=your_search_cx_here

# Optional dedicated key for Google Custom Search. If unset, GOOGLE_API_KEY is
# used. Set this when your Gemini key is bound to a service account that can't
# call Custom Search, so you can use a separate plain key just for search.
# GOOGLE_SEARCH_API_KEY=your_dedicated_search_key_here

# Skip Google Custom Search entirely (saves ~3s/retry when you already know the
# org policy blocks it). Accepts 1/true/yes.
# DISABLE_GOOGLE_SEARCH_API=

# Brave Search API key — primary URL discovery for the auto-extraction flow.
# Returns real ranked results (no LLM hallucination); Gemini grounded search
# stays as the fallback when Brave returns empty or errors.
# BRAVE_SEARCH_API_KEY=your_brave_key_here

# ── WEB SCRAPING (optional) ──────────────────────────────────────────────────

# Firecrawl API key (premium scraper, used as first-tier fallback)
# FIRECRAWL_API_KEY=your_firecrawl_key_here

# Jina AI Reader API key (free-tier JS-capable scraper)
# JINA_API_KEY=your_jina_key_here

# ── MAGENTO INTEGRATION (optional) ───────────────────────────────────────────

# Live product category source. If unset, falls back to product_categories.json.
# MAGENTO_API_URL=https://your-store.example.com/rest/V1
# MAGENTO_BEARER_TOKEN=your_magento_api_token_here

# ── DEBUG FLAGS (optional) ───────────────────────────────────────────────────

# Verbose logging for the image pipeline (search/download/scoring).
# Accepts 1/true/yes.
# IMAGE_DEBUG=

# Print a line when an ApiCallLog write fails (silent by default so logging
# never breaks the caller). Accepts 1/true/yes.
# API_METERING_DEBUG=
