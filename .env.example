# Google Gemini API Key (required for AI generation)
GOOGLE_API_KEY=your_google_api_key_here

# Flask secret key for session management
FLASK_SECRET_KEY=change_this_to_a_random_string

# Google Custom Search (for image search)
GOOGLE_SEARCH_CX=your_search_cx_here

# PostgreSQL Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# EasyPanel internal: postgresql://postgres:YOUR_PASSWORD@pis-postgres:5432/pis_system
# Local dev:          postgresql://postgres:postgres@localhost:5432/pis_system
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pis_system
