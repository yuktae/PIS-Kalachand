# Python build artifacts. The directory names below are anchored with a
# leading `/` so they only match at the repo root — without the anchor,
# `lib/` and `data/` would also hide `tests/ai_tests/lib/` (judge.py +
# judge_cache.py) and `tests/ai_tests/data/` (fixture metadata + proforma
# files), which are real source we want committed.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
/build/
/develop-eggs/
/dist/
/downloads/
/eggs/
/.eggs/
/lib/
/lib64/
/parts/
/sdist/
/var/
/wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
.venv/
env/
ENV/

# Environment variables
.env
.env.local
.env.prod
.env.dev

# Database and Uploads (handled by volumes in Easypanel). Anchored to the
# repo root so the AI-eval suite's `tests/ai_tests/data/` directory and
# anyone else's `instance/` subfolder are left alone.
/instance/
/static/uploads/*
!/static/uploads/.gitkeep
/data/pis_jobs.json

# Runtime status files written by the background cleanup tasks
# (see utils/history_cleanup.py and utils/finalized_cleanup.py).
# Per-environment state, never want to commit.
/static/history_cleanup_status.json
/static/finalized_cleanup_status.json

# Internal planning docs
YUK/

# Sample business PDFs (real documents, not for version control)
/samples/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Claude Code session state (scheduled-task locks, etc.). Local to each
# developer's machine — never want to commit.
.claude/

# OS
.DS_Store
Thumbs.db

# Word / Excel lock files — Office writes these next to an open document
# (`~$report.docx`). They're junk, never want them committed.
~$*

# Generated working logs from manual pytest runs in tests/ai_tests/. The
# curated copies under `tests/ai_tests/results/v*/pytest_full_output.log`
# stay tracked.
tests/ai_tests/v*_pytest_output.log
tests/ai_tests/v*_refresh_output.log
